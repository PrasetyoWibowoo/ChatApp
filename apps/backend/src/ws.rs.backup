use std::time::{Duration, Instant};

use actix::{Actor, ActorContext, AsyncContext, Handler, Message, StreamHandler};
use actix_web::{web, Error, HttpRequest, HttpResponse};
use actix_web_actors::ws;
use base64::{engine::general_purpose, Engine as _};
use dashmap::DashMap;
use std::sync::Arc;
use parking_lot::Mutex;
use serde::{Deserialize, Serialize};
use tokio::sync::broadcast;
use tokio_stream::wrappers::BroadcastStream;
use futures_util::{StreamExt, future::ready};
use sqlx::PgPool;
use uuid::Uuid;
use yrs::{updates::decoder::Decode, Doc, ReadTxn, Transact, Update};

use crate::auth::{extract_user_id_from_token, JwtKeys};
use crate::snapshot;

// (duplicates removed)

pub struct Room {
    pub id: String,
    pub doc: Doc,
    pub last_snapshot: Mutex<Instant>,
}

impl Room {
    pub fn new(id: String) -> Self {
        Self { id, doc: Doc::new(), last_snapshot: Mutex::new(Instant::now()) }
    }
}

#[derive(Clone)]
pub struct WsState {
    pub rooms: DashMap<String, Arc<Room>>,
    pub txs: DashMap<String, broadcast::Sender<String>>,
}

impl WsState { pub fn new() -> Self { Self { rooms: DashMap::new(), txs: DashMap::new() } } }

#[derive(Serialize, Deserialize)]
#[serde(tag = "type", rename_all = "lowercase")]
enum ClientMsg {
    Update { update: String, #[serde(default)] client_id: Option<String> },
    Awareness { update: String, #[serde(default)] client_id: Option<String> },
}

#[derive(Serialize, Deserialize)]
#[serde(tag = "type", rename_all = "lowercase")]
enum ServerMsg {
    Update { update: String, sender: String },
    Awareness { update: String, sender: String },
    Snapshot { update: String },
}

pub async fn ws_index(
    req: HttpRequest,
    stream: web::Payload,
    path: web::Path<String>,
    state: web::Data<WsState>,
    keys: web::Data<JwtKeys>,
    pool: web::Data<PgPool>,
    snapshot_interval: web::Data<std::time::Duration>,
) -> Result<HttpResponse, Error> {
    let doc_id = path.into_inner();
    // Auth from query param token
    let token_opt = req.uri().query().and_then(|q| {
        q.split('&').find_map(|kv| {
            let mut sp = kv.splitn(2, '=');
            let k = sp.next()?;
            let v = sp.next().unwrap_or("");
            if k == "token" { Some(urlencoding::decode(v).ok().map(|s| s.into_owned()).unwrap_or_default()) } else { None }
        })
    });
    let user_id = token_opt
        .ok_or_else(|| actix_web::error::ErrorUnauthorized("Unauthorized"))
        .and_then(|t| extract_user_id_from_token(&t, &keys.decoding).map_err(|_| actix_web::error::ErrorUnauthorized("Unauthorized")))?;

    let room = state
        .rooms
        .entry(doc_id.clone())
        .or_insert_with(|| Arc::new(Room::new(doc_id.clone())))
        .clone();

    // Map slug -> stable UUID using namespace URL; ensure document exists and load last snapshot
    let stable_doc_uuid = Uuid::new_v5(&Uuid::NAMESPACE_URL, format!("collab-notes:{}", doc_id).as_bytes());
    if let Err(e) = snapshot::ensure_document_exists(pool.get_ref(), stable_doc_uuid, user_id).await {
        log::error!("ensure_document_exists failed: {}", e);
    }
    // If room just created (empty doc), attempt to hydrate from latest snapshot
    {
        let tx = room.doc.transact();
        let sv = tx.state_vector();
        let is_empty = sv.len() == 0; // no updates yet
        drop(tx);
        if is_empty {
            if let Ok(Some(bytes)) = snapshot::load_latest_snapshot(pool.get_ref(), stable_doc_uuid).await {
                if let Ok(update) = Update::decode_v1(&bytes) {
                    let mut txn = room.doc.transact_mut();
                    txn.apply_update(update);
                }
            }
        }
    }

    let tx = state
        .txs
        .entry(doc_id.clone())
        .or_insert_with(|| broadcast::channel::<String>(128).0)
        .clone();
    let rx = tx.subscribe();

    let actor = WsSession {
        id: Uuid::new_v4().to_string(),
        room,
        hb: Instant::now(),
        tx,
        rx: Some(rx),
        pool: pool.clone(),
        snapshot_interval: *snapshot_interval.get_ref(),
        document_uuid: stable_doc_uuid,
    };
    ws::start(actor, &req, stream)
}

// HTTP endpoint to fetch latest snapshot for a document (base64-encoded update)
pub async fn snapshot_http(
    path: web::Path<String>,
    pool: web::Data<PgPool>,
    state: web::Data<WsState>,
) -> Result<HttpResponse, Error> {
    let doc_id = path.into_inner();
    // If room is in memory, return a full-state update from the current doc to avoid staleness
    if let Some(room_ref) = state.rooms.get(&doc_id) {
        let tx = room_ref.doc.transact();
        let bytes = tx.encode_state_as_update_v1(&yrs::StateVector::default());
        drop(tx);
        let b64 = general_purpose::STANDARD.encode(bytes);
        return Ok(HttpResponse::Ok().json(serde_json::json!({ "update": b64, "source": "live" })));
    }
    // Fallback to latest persisted snapshot
    let stable_doc_uuid = Uuid::new_v5(&Uuid::NAMESPACE_URL, format!("collab-notes:{}", doc_id).as_bytes());
    match snapshot::load_latest_snapshot(pool.get_ref(), stable_doc_uuid).await {
        Ok(Some(bytes)) => {
            let b64 = general_purpose::STANDARD.encode(bytes);
            Ok(HttpResponse::Ok().json(serde_json::json!({ "update": b64, "source": "db" })))
        }
        Ok(None) => Ok(HttpResponse::NotFound().finish()),
        Err(e) => {
            log::error!("snapshot_http error: {}", e);
            Ok(HttpResponse::InternalServerError().finish())
        }
    }
}

struct WsSession {
    id: String,
    room: Arc<Room>,
    hb: Instant,
    tx: broadcast::Sender<String>,
    rx: Option<broadcast::Receiver<String>>,
    pool: web::Data<PgPool>,
    snapshot_interval: std::time::Duration,
    document_uuid: Uuid,
}

impl Actor for WsSession {
    type Context = ws::WebsocketContext<Self>;

    fn started(&mut self, ctx: &mut Self::Context) {
        // Send full snapshot on connect
        let update = {
            let state = self.room.doc.transact();
            // Send a full snapshot relative to an empty state so new clients get entire document
            let encoded = state.encode_state_as_update_v1(&yrs::StateVector::default());
            encoded
        };
    let b64 = general_purpose::STANDARD.encode(update);
    let msg = serde_json::to_string(&ServerMsg::Snapshot { update: b64 }).unwrap();
        ctx.text(msg);
        self.hb(ctx);

        // Subscribe to room broadcast and forward to this client
        if let Some(rx) = self.rx.take() {
            let stream = BroadcastStream::new(rx)
                .filter_map(|res| ready(res.ok()))
                .map(|s| OutEvent(s));
            ctx.add_message_stream(stream);
        }
    }
}

impl WsSession {
    fn hb(&self, ctx: &mut ws::WebsocketContext<Self>) {
        ctx.run_interval(Duration::from_secs(30), |_act, ctx| {
            ctx.ping(b"ping");
        });
    }
}

impl StreamHandler<Result<ws::Message, ws::ProtocolError>> for WsSession {
    fn handle(&mut self, item: Result<ws::Message, ws::ProtocolError>, ctx: &mut Self::Context) {
        match item {
            Ok(ws::Message::Text(txt)) => {
                if let Ok(msg) = serde_json::from_str::<ClientMsg>(&txt) {
                    match msg {
                        ClientMsg::Update { update, client_id } => {
                            if let Ok(bytes) = general_purpose::STANDARD.decode(update) {
                                if let Ok(update) = Update::decode_v1(&bytes) {
                                    let mut txn = self.room.doc.transact_mut();
                                    txn.apply_update(update);
                                    drop(txn);
                                    // rebroadcast
                                    let b64 = general_purpose::STANDARD.encode(bytes);
                                    let sender = client_id.unwrap_or_else(|| self.id.clone());
                                    let out = serde_json::to_string(&ServerMsg::Update { update: b64, sender }).unwrap();
                                    let _ = self.tx.send(out);
                                    // maybe persist snapshot
                                    let pool = self.pool.clone();
                                    let interval = self.snapshot_interval;
                                    let doc_uuid = self.document_uuid;
                                    let room = self.room.clone();
                                    actix_web::rt::spawn(async move {
                                        let _ = snapshot::maybe_snapshot(pool.get_ref(), &room, interval, doc_uuid).await;
                                    });
                                }
                            }
                        }
                        ClientMsg::Awareness { update, client_id } => {
                            // For now just echo back; clients may choose to ignore self-echo
                            let sender = client_id.unwrap_or_else(|| self.id.clone());
                            let out = serde_json::to_string(&ServerMsg::Awareness { update, sender }).unwrap();
                            let _ = self.tx.send(out);
                        }
                    }
                }
            }
            Ok(ws::Message::Ping(msg)) => ctx.pong(&msg),
            Ok(ws::Message::Pong(_)) => {}
            Ok(ws::Message::Close(reason)) => {
                ctx.close(reason);
                ctx.stop();
            }
            _ => {}
        }
    }
}

// Message passed from broadcast stream into session
struct OutEvent(String);
impl Message for OutEvent { type Result = (); }

impl Handler<OutEvent> for WsSession {
    type Result = ();
    fn handle(&mut self, msg: OutEvent, ctx: &mut Self::Context) -> Self::Result {
        ctx.text(msg.0);
    }
}
