# Database Configuration (matches docker-compose.yml)
DATABASE_URL=postgres://postgres:password@localhost:5433/realtime_notes

# Server Configuration
BIND_ADDR=127.0.0.1:8080

# JWT Secret (change this in production!)
JWT_SECRET=your-secret-key-change-this-in-production

# Email Verification (Resend)
# Free tier: https://resend.com
# For best deliverability (avoid spam), verify a domain in Resend and set RESEND_FROM_EMAIL
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=ChatApp <onboarding@resend.dev>

# Optional: set to "log" to not send real emails (codes will be logged)
EMAIL_PROVIDER=resend

# Rust Log Level
RUST_LOG=info
