# Database Configuration (matches docker-compose.yml)
DATABASE_URL=postgres://postgres:password@localhost:5433/realtime_notes

# Server Configuration
BIND_ADDR=127.0.0.1:8080

# JWT Secret (change this in production!)
JWT_SECRET=your-secret-key-change-this-in-production

# Email Verification (Resend)
# Railway free tier often blocks outbound SMTP, so use an HTTP email API.
# Provider options:
# - sendgrid: SendGrid HTTP API
# - resend: Resend HTTP API
# - log: don't send email (codes will be logged)

# Recommended for broader testing:
# SendGrid (HTTP API)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=ChatApp <no-reply@your-domain.com>

# Resend (HTTP API) (optional / legacy)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=ChatApp <onboarding@resend.dev>

# Set provider explicitly
EMAIL_PROVIDER=sendgrid

# Rust Log Level
RUST_LOG=info
